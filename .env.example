# 复制为 server/.env 或项目根 .env（启动 API 前加载）
SESSION_SECRET=请改为随机长字符串
PORT=3889

# OA 开放平台（客户信息同步）
OA_API_BASE_URL=https://wx.hnzhcyy.cn
OA_API_KEY=在OA开放平台创建，勿提交到Git
# 可选：分页间隔(ms，默认600)、限流重试等待(ms，默认2500)
# OA_PAGE_DELAY_MS=600
# OA_RATE_LIMIT_RETRY_MS=2500
# 可选，默认与《客户信息接口文档》一致
# OA_APP_ID=50cf5a8c1217c1b137c55032
# OA_CUSTOMER_ENTRY_ID=56ac09c06e2dd06a08f7ed6c
